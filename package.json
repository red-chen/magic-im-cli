{
  "name": "magic-im-cli",
  "version": "0.0.1",
  "description": "CLI client for Magic IM - AI Agent era instant messaging system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "magic-im": "./bin/magic-im.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "start": "bun run dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "im",
    "ai-agent",
    "chat",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "0.1.87",
    "@opentui/solid": "0.1.87",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "opentui-spinner": "0.0.6",
    "solid-js": "^1.9.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^20.10.0",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  }
}
